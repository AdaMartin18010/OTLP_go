# ============================================
# OTLP Go - Docker Ignore File
# 优化构建上下文，减少镜像大小和构建时间
# ============================================

# ============================================
# 版本控制
# ============================================
.git
.gitignore
.gitattributes
.gitmodules
.github

# ============================================
# IDE 和编辑器
# ============================================
.vscode
.idea
.fleet
.history
*.swp
*.swo
*~
*.orig
*.rej
*.patch
*.diff

# ============================================
# 操作系统文件
# ============================================
**/.DS_Store
Thumbs.db
*.lnk

# ============================================
# 文档（构建时不需要）
# ============================================
docs/
*.md
!README.md
LICENSE
CONTRIBUTING.md

# ============================================
# 脚本和工具（构建时不需要）
# ============================================
*.ps1
*.sh
*.bat

# ============================================
# CI/CD 配置
# ============================================
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
Jenkinsfile

# ============================================
# 测试相关
# ============================================
*_test.go
*_test.go.txt
**/__snapshots__
**/.coverage
coverage.out
coverage.html
testdata/
*.test
*.prof
*.pprof

# ============================================
# 构建输出
# ============================================
bin/
build/
dist/
out/
obj/
tmp/
.cache/

# ============================================
# 依赖目录（如果在子目录中有）
# ============================================
**/node_modules/
**/vendor/
**/.venv/
**/venv/
**/__pycache__/
*.pyc

# ============================================
# 日志和临时文件
# ============================================
*.log
*.tmp
*.temp
*.bak
*.old
logs/

# ============================================
# Docker 相关（避免递归复制）
# ============================================
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# ============================================
# 敏感信息
# ============================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
secrets/
credentials/

# ============================================
# 报告和统计文件
# ============================================
COMPLETION_REPORT.md
COMPREHENSIVE_*.md
DOCUMENTATION_*.md
FINAL_*.md
FIXES_*.md
GO126_*.md
NEXT_STEPS_*.md
PROJECT_*.md
WARNING_*.md
STATISTICS.md
benchmark_results.txt

# ============================================
# 项目特定文件
# ============================================
ai.md
ARCHITECTURE.md
TECH_STACK.md
WORKSPACE.md
QUICK_*.md
INDEX.md
HOW_TO_*.md
OTLP_*.md
SYSTEM_*.md
SEMANTIC_*.md

# ============================================
# 保留必要文件
# ============================================
!configs/
!configs/**
