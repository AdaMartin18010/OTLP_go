# ============================================
# OTLP Go - Environment Variables Example
# 复制此文件为 .env 并根据需要修改
# ============================================

# ============================================
# 应用配置
# ============================================
GO_ENV=development
VERSION=1.0.0
LOG_LEVEL=info

# ============================================
# OTLP 端点配置
# ============================================
OTLP_GRPC_ENDPOINT=otel-collector:4317
OTLP_HTTP_ENDPOINT=otel-collector:4318
OTLP_INSECURE=true

# ============================================
# 可观测性开关
# ============================================
METRICS_ENABLED=true
TRACING_ENABLED=true
LOGS_ENABLED=true
PROFILING_ENABLED=false

# ============================================
# Grafana 配置
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================
# 构建参数
# ============================================
BUILD_TIME=
GIT_COMMIT=
GIT_BRANCH=
